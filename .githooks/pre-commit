#!/usr/bin/env bash
# pre-commit hook — cube stage-gate workflow
#
# Blocks commits that modify locked test files (test code and test resources).
# Uses test_file_pattern from workflow.yaml to match only test files, not all
# files in test_dir (supports co-located test setups like TypeScript/Next.js).
#
# Install: git config core.hooksPath .githooks

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
LOCK_DIR="$REPO_ROOT/.git/locks"
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)"
SAFE_BRANCH="${BRANCH//\//-}"
STATE_FILE="$REPO_ROOT/.cube/iterations/$SAFE_BRANCH/state.yaml"
WORKFLOW_FILE="$REPO_ROOT/.cube/config/workflow.yaml"

# Returns 0 (true) if the basename of FILE matches the glob PATTERN
file_matches_pattern() {
  local file="$1"
  local pattern="$2"
  [ -z "$pattern" ] && return 0  # no pattern = match all
  local base
  base="$(basename "$file")"
  case "$base" in
    $pattern) return 0 ;;
    *) return 1 ;;
  esac
}

get_state_test_pattern() {
  [ -f "$WORKFLOW_FILE" ] || { echo ""; return; }
  grep -E '^[[:space:]]*test_file_pattern:' "$WORKFLOW_FILE" \
    | head -1 \
    | sed 's/^[[:space:]]*test_file_pattern:[[:space:]]*//' \
    | sed 's/[[:space:]]*#.*$//' \
    | sed 's/^"\(.*\)"$/\1/' \
    | sed "s/^'\(.*\)'$/\1/" \
    | xargs 2>/dev/null || echo ""
}

get_locked_dirs_from_state() {
  [ -f "$STATE_FILE" ] || return 0
  [ -f "$WORKFLOW_FILE" ] || return 0

  CURRENT_STAGE="$(grep '^current_stage:' "$STATE_FILE" | head -1 | cut -d: -f2- | xargs || true)"
  case "$CURRENT_STAGE" in
    04-development|05-testing) ;;
    *) return 0 ;;
  esac

  grep -E '^[[:space:]]*(test_dir|test_resource_dir):' "$WORKFLOW_FILE" \
    | sed 's/^[[:space:]]*\(test_dir\|test_resource_dir\):[[:space:]]*//' \
    | sed 's/[[:space:]]*#.*$//' \
    | sed 's/^"\(.*\)"$/\1/' \
    | sed "s/^'\(.*\)'$/\1/" \
    | sed '/^[[:space:]]*$/d'
}

# ---- Check: Locked test files and test resources ----
STAGED=$(git diff --cached --name-only)
BLOCKED=""

# Check files from .git/locks/*.lock entries (set by cube-lock)
if [ -d "$LOCK_DIR" ]; then
  for lock_file in "$LOCK_DIR"/*.lock; do
    [ -f "$lock_file" ] || continue
    TESTS_DIR=$(grep "^tests_dir=" "$lock_file" | cut -d= -f2-)
    [ -z "$TESTS_DIR" ] && continue
    TESTS_DIR="${TESTS_DIR%/}"
    LOCK_PATTERN=$(grep "^file_pattern=" "$lock_file" | cut -d= -f2-)
    for staged_file in $STAGED; do
      case "$staged_file" in
        "$TESTS_DIR"|"$TESTS_DIR"/*)
          if file_matches_pattern "$staged_file" "$LOCK_PATTERN"; then
            BLOCKED="$BLOCKED $staged_file"
          fi
          ;;
      esac
    done
  done
fi

# Check files from state.yaml (active during 04-development and 05-testing)
STATE_LOCKED_DIRS="$(get_locked_dirs_from_state)"
STATE_TEST_PATTERN="$(get_state_test_pattern)"

if [ -n "$STATE_LOCKED_DIRS" ]; then
  for tests_dir in $STATE_LOCKED_DIRS; do
    tests_dir="${tests_dir%/}"
    [ -z "$tests_dir" ] && continue
    for staged_file in $STAGED; do
      case "$staged_file" in
        "$tests_dir"|"$tests_dir"/*)
          if file_matches_pattern "$staged_file" "$STATE_TEST_PATTERN"; then
            BLOCKED="$BLOCKED $staged_file"
          fi
          ;;
      esac
    done
  done
fi

if [ -n "$BLOCKED" ]; then
    echo "ERROR: Commit blocked — modifications to locked test files"
    echo ""
    echo "Locked test files cannot be modified directly. Blocked files:"
    for f in $BLOCKED; do
      echo "   - $f"
    done
    echo ""
    echo "If you MUST modify tests or test resources:"
    echo "   1. If the contract changed, use /cube:regress 02-design or /cube:regress 03-test-cases"
    echo "   2. For narrow local edits only, run: cube-unlock \"your reason here\""
    echo "   3. Make the changes"
    echo "   4. Re-lock with: cube-lock"
    echo "   5. Retry the commit"
    exit 1
fi

exit 0
